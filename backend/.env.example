# Neo-Fiber backend environment variables
# Copy to backend/.env and fill in values. Never commit .env.
#
# Run with: cd backend && npm run dev

# ---- Databases -----------------------------------------------------------

# Application DB — PostGIS-enabled, owned by this app.
# Matches docker-compose.dev.yaml app-db service defaults.
APP_DB_URL=postgres://neo_fiber:neo_fiber_dev@localhost:5432/neo_fiber

# Data Warehouse — read-only, external Zain Sudan DWH Postgres.
# Not reachable from GitHub Actions CI runners (Phase 0 Q3 / §12.5).
# Set to your deploy host's DWH address.
DWH_URL=postgres://readonly_user:password@172.18.x.x:5432/dwh_db

# ---- Authentication -------------------------------------------------------

# LDAP server (reachable from deploy host; NOT from CI — Phase 0 Q3)
LDAP_URL=ldap://ldap.sd.zain.com
LDAP_BIND_DN_TEMPLATE=uid={username},ou=users,dc=sd,dc=zain,dc=com

# Set true in local dev / CI to bypass LDAP and use bcrypt app users.
# Do NOT use in production — LDAP is the production auth path.
AUTH_LOCAL_ONLY=false

# JWT signing key — generate with: openssl rand -hex 32
# Must be ≥ 32 characters.
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# JWT lifetime (default 8 h = one work shift). See DESIGN.md §9 A4.
JWT_TTL_SECONDS=28800

# ---- Alarm filtering ------------------------------------------------------

# The exact Alarm_Name string that represents a fiber cut in dwh.fibergis_alarm_log.
# When empty (default), NO alarm triggers reachability recompute — safe until known.
# See DESIGN.md §7 premise 8. Example value: R_LOS
FIBER_CUT_ALARM_NAME=

# ---- Polling & streaming --------------------------------------------------

# DWH poll interval. Default 30 s — DWH has 1–2 min new-row latency (Phase 0 Q4).
# Lowering below 30 s gives no fresher data and proportional DB cost.
DWH_POLL_INTERVAL_MS=30000

# SSE keepalive to defeat corporate proxy idle-timeout. See DESIGN.md §9 A6.
SSE_HEARTBEAT_MS=25000

# ---- Logging & runtime ---------------------------------------------------

LOG_LEVEL=info
NODE_ENV=development
PORT=5000
