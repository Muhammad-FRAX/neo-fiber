{
  "name": "app-backend",
  "version": "1.0.0",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts up",
    "migrate:down": "tsx src/db/migrate.ts down",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "mohamed ali",
  "license": "ISC",
  "description": "Neo-Fiber backend — Express 5 ESM, PostGIS, real-time SSE",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "ldapjs": "^3.0.7",
    "pg": "^8.14.1",
    "pino": "^9.7.0",
    "zod": "^3.25.49"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.25.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/ldapjs": "^3.0.5",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.11.14",
    "@types/supertest": "^6.0.3",
    "nodemon": "^3.1.11",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.1.0",
    "testcontainers": "^10.25.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  }
}
